# Copy this file to `.env` and adjust if your checkout lives elsewhere.
#
# The path is relative to prisma/ (Prisma's working directory when running
# `prisma db push`), so `../db/custom.db` resolves to <repo-root>/db/custom.db.
DATABASE_URL=file:../db/custom.db

# Optional: Python interpreter the execute route uses (defaults to <cwd>/.venv/bin/python3)
# SCRIPT_MANAGER_PYTHON=/Users/lijing/Projects/script-manager/.venv/bin/python3
